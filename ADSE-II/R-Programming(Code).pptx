#for
loop<-1:10;
for(data in loop){
  print(paste(data, "Hell0 "));
}

for(data in 20:26){
  print(data);
}

veg<-c("Carrot", "Cucumber", "Eggplant", "Onion");
for(sabzi in veg){
  print(sabzi);
}

#break
x<-c("Welcome", "to", "R", "programming");
y<-1;
repeat{
  print(x);
  y<-y+1;
  if(y>3){
    break;
  }
}















