v1<-c(2,4,6,8);
v2<-c(1,3,5,7);
print(v1+v2);
print(v1-v2);
print(v1*v2);
print(v1/v2);


x<-c(2.5, TRUE, 3+7i)
y<-c("abc", TRUE, 1-8i)
print(x&y)

age<-19;
if(is.integer(age)){
  print("Yes");
}else{
  print("No");
}

find<-c("education", "is", "the", "key", "to", "unlock", "the", "golden", "door", "of", "freedom");

if("unlock" %in% find){
  print("Available");
}else{
  print("NOT Available");
}

#Switch
x<-switch(2,"Hello", "R", "Programming");
print(x);

a<-"20";
x<-switch(a,
  "5"="Ali",
  "10"="Ahsan", 
  "15"="Ahmed", 
  "20"="Ammar")
print(x);

#next
n<-1:10;
for(res in n){
  if(res == 6){
    next;
  }
  print(n);
}

